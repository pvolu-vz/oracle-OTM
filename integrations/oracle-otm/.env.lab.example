# =============================================================
# Oracle OTM → Veza OAA Integration  —  LAB Environment
# =============================================================
# Copy this file to .env.lab and fill in real values.
# Never commit .env.lab — it is git-ignored.
#
# This lab config uses an ODBC DSN with IAM credentials,
# bypassing Azure AD entirely. See aws-lab-setup/ for setup steps.
# =============================================================

# --- Veza Configuration ---
# For dry-run (Mode A), any non-empty placeholder values work.
# For lab push (Mode B), set your actual lab Veza URL and API key.
VEZA_URL=https://your-lab.veza.com
VEZA_API_KEY=your_lab_veza_api_key_here

# --- OAA Provider / Datasource Labels ---
PROVIDER_NAME=Oracle OTM Lab
DATASOURCE_NAME=Oracle OTM Lab

# --- Athena ODBC: DSN mode (bypasses Azure AD entirely) ---
# Set to the DSN name configured in /etc/odbc.ini (Linux) or ~/.odbc.ini (macOS).
# When this is set, all Option B / Azure AD fields below are ignored by the script.
ATHENA_ODBC_DSN=otm-lab

# --- Azure AD Authentication (NOT USED in DSN mode — kept for reference only) ---
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
# ATHENA_UID=
# ATHENA_PWD=

# --- Athena connection details (used inside the ODBC DSN, not read directly by the script) ---
# ATHENA_REGION=us-east-1
# ATHENA_S3_OUTPUT=s3://<LabPrefix>-athena-results/
# ATHENA_CATALOG=AwsDataCatalog
# ATHENA_DATABASE=dtl_otm
# ATHENA_WORKGROUP=lab
