# =============================================================
# Oracle OTM → Veza OAA Integration  —  Environment Variables
# =============================================================

# --- Veza Configuration ---
VEZA_URL=your-company.veza.com
VEZA_API_KEY=your_veza_api_key_here

# --- OAA Provider Settings (optional overrides) ---
# PROVIDER_NAME=Oracle OTM
# DATASOURCE_NAME=Oracle OTM

# --- Athena ODBC Connection ---
# Option A: Use a pre-configured ODBC DSN name (if set, Option B fields are ignored)
# ATHENA_ODBC_DSN=edl-datalake

# Option B: DSN-less connection (all fields required if DSN is blank)
ATHENA_REGION=us-east-1
ATHENA_S3_OUTPUT=s3://wrk-techdevops-prod-athena-query-results/ops
ATHENA_CATALOG=AwsDataCatalog
ATHENA_DATABASE=dtl_otm
ATHENA_WORKGROUP=datalake

# --- Azure AD Authentication for Athena ---
AZURE_AD_CLIENT_ID=your_azure_ad_client_id_here
AZURE_AD_CLIENT_SECRET=your_azure_ad_client_secret_here
AZURE_AD_TENANT_ID=your_azure_ad_tenant_id_here
ATHENA_UID=your_email@westrock.com
ATHENA_PWD=your_password_here
